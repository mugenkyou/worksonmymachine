# ---------------------------------------------------------
# Python bytecode cache
# ---------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo

# ---------------------------------------------------------
# TITAN generated experiment outputs
# ---------------------------------------------------------

# Experiment run outputs (datasets, metadata, summaries)
experiments/
runs/

# Dataset export folders
TITAN/logs/*.csv
TITAN/logs/*.parquet
TITAN/logs/*.json

# Catch any loose generated data files anywhere in the tree
*.csv
*.parquet

# Metadata / summary JSON files generated by ExperimentRunner
# (but NOT source JSON configs — be specific with paths)
experiments/**/*.json
TITAN/logs/**/*.json

# ---------------------------------------------------------
# Common Python / tooling
# ---------------------------------------------------------

# Distribution / packaging
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Local secrets
local.env
.env
.env.*

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/

# IDE
.vscode/settings.json
.idea/

# OS
.DS_Store
Thumbs.db