flowchart TB
    subgraph Training["🎓 RL Training Pipeline"]
        TR1["TITAN Env\n(Trajectory Collection)"]
        TR2["reward_v2.py\n(Multi-Objective Signal)"]
        TR3["GRPO Training\n(Unsloth + TRL)"]
        TR4["Qwen2.5-1.5B\n(Fine-tuned Model)"]
        TR5["Checkpoint\nmodels/grpo_titan_final"]
    end

    subgraph Clients[Clients]
        U1[Inference Runner]
        U2[OpenEnv Validator]
        U3[HTTP Clients]
    end

    subgraph Orchestration[Orchestration Layer]
        O1[inference.py]
        O2[Prompt Builder]
        O3[LLM Call]
        O4[Action Parser]
    end

    subgraph Serve[Serving Layer]
        S1[stratos_env.server.app]
        S2[GET /ping /health]
        S3[GET /state]
        S4[POST /reset]
        S5[POST /step]
    end

    subgraph Interface[OpenEnv Interface Layer]
        I1[openenv_wrapper.StratosEnv]
        I2[models.py\nAction Observation Reward]
        I3[action_mapping.py]
        I4[llm_interface.py]
    end

    subgraph Eval[Task and Evaluation Layer]
        T1[tasks.registry]
        T2[task_easy task_medium task_hard]
        T3[evaluation.trajectory]
        T4[evaluation.scoring]
        T5[graders easy medium hard]
    end

    subgraph Core[Simulation Core]
        C1[core.environment.stratos_env]
        C2[state_model.py]
        C3[fault_injection.py]
        C4[actions.py]
        C5[reward_v2.py]
    end

    subgraph Deploy[Deployment and Validation]
        D1[Dockerfile]
        D2[scripts/validate-submission.sh]
        D3[scripts/hardening_check.py]
    end

    %% Training Flow
    TR1 --> TR2
    TR2 --> TR3
    TR3 --> TR4
    TR4 --> TR5
    TR5 -.->|loads| O3
    C5 -.->|feeds| TR2

    %% Inference Flow
    U1 --> O1
    O1 --> T1
    T1 --> T2
    O1 --> O2
    O2 --> O3
    O3 --> O4
    O4 --> I4
    O1 --> T3
    T3 --> T4
    T4 --> T5
    O1 --> I1

    %% Service Flow
    U2 --> S1
    U3 --> S1
    S1 --> S2
    S1 --> S3
    S1 --> S4
    S1 --> S5
    S1 --> I1

    %% Interface to Core
    I1 --> I2
    I1 --> I3
    I1 --> C1
    C1 --> C2
    C1 --> C3
    C1 --> C4
    C1 --> C5

    %% Deployment
    D1 --> S1
    D2 --> U2
    D3 --> U1
